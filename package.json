{
  "name": "birdlist",
  "version": "1.2.1",
  "scripts": {
    "dev": "vite",
    "build": "vite build && workbox injectManifest workbox-config.js && npm run copy:sw",
    "copy:sw": "node -e \"require('fs').copyFileSync('dist/sw.js','public/sw.js')\"",
    "preview": "vite preview --port 4173",
    "test:unit": "vitest --environment jsdom",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs --fix --ignore-path .gitignore",
    "start": "node index.js",
    "keys:vapid": "web-push generate-vapid-keys"
  },
  "dependencies": {
    "@khmyznikov/pwa-install": "^0.3.9",
    "@oddbird/css-anchor-positioning": "^0.9.0",
    "@vueuse/rxjs": "^10.11.1",
    "body-parser": "^1.19.2",
    "cors": "^2.8.5",
    "dexie": "^4.0.11",
    "dexie-cloud-addon": "^4.0.12",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "node-fetch": "^2.7.0",
    "pinia": "^2.3.1",
    "pinia-plugin-persistedstate": "^3.2.3",
    "rxjs": "^7.8.2",
    "vue": "^3.5.32",
    "vue-router": "^4.6.4",
    "vue3-simple-typeahead": "^1.0.11",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@rushstack/eslint-patch": "^1.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^8.57.1",
    "eslint-plugin-vue": "^9.33.0",
    "jsdom": "^20.0.3",
    "prettier": "2.8.1",
    "vite": "^8.0.5",
    "vitest": "^4.1.2",
    "workbox-cli": "^6.6.0"
  }
}
