    "dexie-cloud-addon": "^4.0.12",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "node-fetch": "^2.7.0",
    "pinia": "^2.3.1",
    "pinia-plugin-persistedstate": "^3.2.3",
    "rxjs": "^7.8.2",
    "vue": "^3.5.17",
